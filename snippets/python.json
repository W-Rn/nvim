{
    "main": {
        "prefix": "main",
        "body": [
            "def main():",
            "\t${0}",
            "",
            "",
            "if __name__ == \"__main__\":",
            "\tmain()"
        ]
    },
    "if/else": {
        "prefix": "ife",
        "body": [
            "if ${1:condition}:",
            "\t${2:pass}",
            "else:",
            "\t${0}"
        ]
    },
    "for loop": {
        "prefix": "for",
        "body": [
            "for ${1:i} in ${2:iterable}:",
            "\t${0}"
        ]
    },
    "try/except": {
        "prefix": "try",
        "body": [
            "try:",
            "\t${1:pass}",
            "except ${2:Exception} as e:",
            "\t${0:raise e}"
        ]
    },
    "list comprehension": {
        "prefix": "list",
        "body": [
            "[${1:x} for ${1:x} in ${2:iterable} if ${3:condition}]"
        ]
    },
    "print f-string": {
        "prefix": "pf",
        "body": [
            "print(f\"${1:label}: {${2:value}}\")"
        ]
    }
}
